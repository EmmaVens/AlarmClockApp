<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101820"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="50dp"
        android:paddingBottom="50dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Умный будильник"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/currentTimeText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Текущее время"
            android:textColor="#BFD7EA"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/addAlarmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавить будильник"
            android:textSize="18sp"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Список будильников:"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/alarmListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:id="@+id/ringingPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="#D7263D"
            android:padding="20dp"
            android:layout_marginTop="30dp">

            <TextView
                android:id="@+id/ringingTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="БУДИЛЬНИК ЗВОНИТ!"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/shakeCounterText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сделайте 5 движений как при ходьбе"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:gravity="center" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>